# ============================================================
# Plataforma Unidos — variables de entorno (plantilla)
# Copia este archivo a .env.local en cada app y rellena valores.
# NUNCA subas .env.local al repositorio.
# ============================================================

# --- Supabase (proyecto en https://supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci...anon"

# Solo en el servidor (Server Actions / Route Handlers / cron). NUNCA en el cliente.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci...service_role"

# --- CAPTCHA anti-bot (Cloudflare Turnstile) en login y registro ---
# Site key (pública) del widget. Vacía = sin CAPTCHA (dev). El "secret" se
# configura en Supabase (Authentication → Bot & Abuse → Turnstile), no aquí.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# --- Correo transaccional (Resend) — solo servidor ---
# API key de https://resend.com (Server Actions). NUNCA en el cliente.
# OJO: estas variables son para los correos PROPIOS de la app (p. ej. contraseña temporal
# al crear un usuario). Los correos de AUTH (recuperar/restablecer contraseña, confirmar
# cuenta, magic link…) los envía SUPABASE, no la app: configura Resend como SMTP del
# proyecto de Supabase (Authentication → Emails → SMTP Settings). Ver docs/08-CORREO-RESEND.md.
RESEND_API_KEY=""
# Remitente verificado en Resend (hasta verificar dominio, usa onboarding@resend.dev,
# que solo entrega al correo dueño de la cuenta de Resend).
RESEND_FROM="UnidosXVenezuela <onboarding@resend.dev>"

# --- Google Safe Browsing (verificación de enlaces de casos) — solo servidor ---
# Clave de la Safe Browsing API v4: Google Cloud Console → APIs y servicios →
# habilita "Safe Browsing API" → Credenciales → Clave de API. Restríngela a esa
# API (sin restricción de referente HTTP: se usa desde el servidor). Se consulta
# al crear/editar un caso. Vacía = no verifica con Google (solo análisis local).
GOOGLE_SAFE_BROWSING_API_KEY=""

# --- App móvil (Expo) ---
EXPO_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci...anon"

# --- Notificaciones push web (Web Push / VAPID) ---
# Genera el par de claves una sola vez:  npx web-push generate-vapid-keys
# La PÚBLICA va al cliente (por eso NEXT_PUBLIC_); la PRIVADA solo al servidor.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Contacto del emisor (requerido por el estándar); un mailto o una URL tuya.
VAPID_SUBJECT="mailto:soporte@unidosxvnezuela.com"
# Secreto compartido con el Database Webhook de Supabase (cabecera x-webhook-secret).
PUSH_WEBHOOK_SECRET=""

# --- Telegram (canal de avisos, opcional) — ver docs/TELEGRAM.md ---
# Token del bot (de @BotFather). SOLO servidor. Vacío = canal desactivado.
TELEGRAM_BOT_TOKEN=""
# Secreto compartido con setWebhook (cabecera X-Telegram-Bot-Api-Secret-Token). SOLO servidor.
TELEGRAM_WEBHOOK_SECRET=""
# @usuario del bot, sin la @ (para el deep-link t.me/<bot>). Público.
NEXT_PUBLIC_TELEGRAM_BOT=""
# URL base pública del despliegue (para el botón que abre la app desde Telegram). Público.
NEXT_PUBLIC_APP_URL="https://tu-dominio"

# --- Notificaciones push móvil (Expo, pendiente) ---
# EXPO_ACCESS_TOKEN=""

# --- Mapas (opcional) ---
# NEXT_PUBLIC_MAPLIBRE_STYLE_URL=""
