VAPID_SUBJECT="mailto:soporte@unidosxvnezuela.com"
PUSH_WEBHOOK_SECRET=""

# Telegram (canal de avisos, opcional) — ver docs/TELEGRAM.md. Vacío = desactivado.
# Token del bot (@BotFather) y secreto del webhook: SOLO servidor.
