# Google Safe Browsing (verifica los enlaces de casos) — solo servidor.
# Vacío = no verifica con Google (queda el análisis heurístico local).
GOOGLE_SAFE_BROWSING_API_KEY=""

# Consulta de cédula (CNE) para el Grupo de Búsqueda — solo servidor.
# REQUERIDO para activar la herramienta (sin esto el panel avisa que no está
# configurada). El host público anterior (api.megacreativo.com) fue discontinuado.
# Usa un proveedor compatible con CedulaVE: el script MIT auto-hospedado o un
# espejo vigente. Formato: ?nac=V&dni=XXXXXXXX → JSON { status, response:{...} }.
CEDULA_VE_API_URL=""
CEDULA_VE_API_TOKEN=""   # opcional: token Bearer si el proveedor lo exige

# Notificaciones push web (VAPID). Genera el par:  npx web-push generate-vapid-keys
# La pública va al cliente; la privada y el secreto SOLO al servidor. Vacío = no envía.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:soporte@unidosxvnezuela.com"
PUSH_WEBHOOK_SECRET=""
