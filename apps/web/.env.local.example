NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci...anon"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci...service_role"

# CAPTCHA (Cloudflare Turnstile). Vacío = sin CAPTCHA (dev). El secret va en Supabase.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Correo transaccional (Resend) — solo servidor. Vacío = no envía.
RESEND_API_KEY=""
RESEND_FROM="UnidosXVenezuela <onboarding@resend.dev>"

# Google Safe Browsing (verifica los enlaces de casos) — solo servidor.
# Vacío = no verifica con Google (queda el análisis heurístico local).
GOOGLE_SAFE_BROWSING_API_KEY=""

# Consulta de cédula (CNE) para el Grupo de Búsqueda — solo servidor.
# REQUERIDO para activar la herramienta (sin esto el panel avisa que no está
# configurada). El host público anterior (api.megacreativo.com) fue discontinuado.
# Opción A (recomendada) — cedula.com.ve hospedado (de pago; app_id + token):
CEDULA_COM_VE_APP_ID=""
CEDULA_COM_VE_TOKEN=""
CEDULA_COM_VE_URL=""   # opcional; por defecto https://api.cedula.com.ve/api/v1
# Opción B — compatible con CedulaVE (MegaCreativo, MIT) auto-hospedado o espejo:
CEDULA_VE_API_URL=""
CEDULA_VE_API_TOKEN=""   # opcional: token Bearer si el proveedor lo exige

# Notificaciones push web (VAPID). Genera el par:  npx web-push generate-vapid-keys
# La pública va al cliente; la privada y el secreto SOLO al servidor. Vacío = no envía.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:soporte@unidosxvnezuela.com"
PUSH_WEBHOOK_SECRET=""
